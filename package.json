{
  "name": "capcop",
  "displayName": "CapCop",
  "description": "A VS Code extension for CapCop functionality",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "capcop",
    "productivity",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AnywhereAiOps/CapCop"
  },
  "bugs": {
    "url": "https://github.com/AnywhereAiOps/CapCop/issues"
  },
  "homepage": "https://github.com/AnywhereAiOps/CapCop#readme",
  "license": "Apache-2.0",
  "author": {
    "name": "AnywhereAiOps"
  },
  "publisher": "anywhereaiops",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "capcop.helloWorld",
        "title": "Hello World",
        "category": "CapCop"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run build && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run build",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {}
}